# --- Race to the Moon · configuration -------------------------------------

# GitHub access token. REQUIRED for live data, because the hackathon repos are
# private. Use a fine-grained token with "Contents: read-only" on the three
# repos, or a classic token with the "repo" scope.
# Without a token the dashboard automatically runs in DEMO mode.
GITHUB_TOKEN=

# Port the dashboard is served on.
PORT=4000

# Force demo data even when a token is set (handy for previewing the visuals).
# Set to 1 / true to enable.
DEMO=

# How often the server pulls fresh numbers from GitHub, in milliseconds.
REFRESH_MS=30000
